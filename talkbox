#!/usr/bin/env bash
# talkbox — one command to rule the kiosk.
#
#   talkbox update       pull from git, rebuild + relaunch, publish Twilio
#                        webhook, health-check. The works.
#   talkbox twilio-sync  publish webhook to Twilio only, then sync backend
#                        container env if needed.
#   talkbox status       containers, health, public URL, Twilio voice URL
#   talkbox restart   restart the docker stack (no rebuild)
#   talkbox logs      tail backend logs (or: talkbox logs <service>)
#
# Install once:  ./talkbox install   (symlinks into ~/.local/bin)

set -euo pipefail

# ── Locations ─────────────────────────────────────────────────────────────────
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
REPO_DIR="$(dirname "$SCRIPT_PATH")"
ENV_FILE="$REPO_DIR/app/.env"
BACKEND_PORT="${BACKEND_PORT:-8085}"
FRONTEND_PORT="${FRONTEND_PORT:-8084}"
TWIML_ROUTE="/api/kiosk/call/twiml"

# ── Pretty output ─────────────────────────────────────────────────────────────
if [ -t 1 ]; then
    BOLD='\033[1m'; DIM='\033[2m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
    RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
else
    BOLD=''; DIM=''; GREEN=''; YELLOW=''; RED=''; CYAN=''; NC=''
fi

STEP_N=0; STEP_TOTAL=0
step() { STEP_N=$((STEP_N + 1)); echo -e "\n${CYAN}${BOLD}[$STEP_N/$STEP_TOTAL]${NC} ${BOLD}$*${NC}"; }
ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
warn() { echo -e "  ${YELLOW}!${NC} $*"; }
fail() { echo -e "  ${RED}✗${NC} $*" >&2; exit 1; }
note() { echo -e "  ${DIM}$*${NC}"; }

banner() {
    echo -e "${CYAN}${BOLD}"
    echo '  ╔════════════════════════════════════╗'
    echo '  ║      T A L K B O X   K I O S K     ║'
    echo '  ╚════════════════════════════════════╝'
    echo -e "${NC}"
}

# ── Helpers ───────────────────────────────────────────────────────────────────
env_val() { grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"' | tr -d "'"; }

require_env() {
    [ -f "$ENV_FILE" ] || fail "Missing $ENV_FILE — copy app/.env.example and configure it."
    TWILIO_ACCOUNT_SID="$(env_val TWILIO_ACCOUNT_SID)"
    TWILIO_AUTH_TOKEN="$(env_val TWILIO_AUTH_TOKEN)"
    TWIML_APP_SID="$(env_val TWILIO_TWIML_APP_SID)"
    RAW_PUBLIC_URL="$(env_val TWILIO_PUBLIC_URL)"
    [ -n "$TWILIO_ACCOUNT_SID" ] && [ -n "$TWILIO_AUTH_TOKEN" ] || fail "TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN not set in .env"
    [ -n "$TWIML_APP_SID" ] || fail "TWILIO_TWIML_APP_SID not set in .env"
    [ -n "$RAW_PUBLIC_URL" ] || fail "TWILIO_PUBLIC_URL not set in .env"

    PUBLIC_BASE_URL="$(normalize_public_base_url "$RAW_PUBLIC_URL")"
    [ -n "$PUBLIC_BASE_URL" ] || fail "TWILIO_PUBLIC_URL is invalid: $RAW_PUBLIC_URL"
    WEBHOOK_URL="${PUBLIC_BASE_URL}${TWIML_ROUTE}"
}

normalize_public_base_url() {
    local input="$1"
    local base="$input"

    # Accept either the base URL or a full webhook URL and normalize to base.
    if [[ "$base" == *"$TWIML_ROUTE" ]]; then
        base="${base%"$TWIML_ROUTE"}"
    fi
    base="${base%/}"
    printf '%s' "$base"
}

publish_to_twilio() {
    note "Publishing voice webhook to Twilio TwiML App ${TWIML_APP_SID:0:10}…"
    local status
    status=$(curl -s -o /tmp/talkbox-twilio.json -w "%{http_code}" \
        -X POST "https://api.twilio.com/2010-04-01/Accounts/${TWILIO_ACCOUNT_SID}/Applications/${TWIML_APP_SID}.json" \
        -u "${TWILIO_ACCOUNT_SID}:${TWILIO_AUTH_TOKEN}" \
        --data-urlencode "VoiceUrl=${WEBHOOK_URL}" \
        --data-urlencode "VoiceMethod=POST")
    if [ "$status" != "200" ]; then
        cat /tmp/talkbox-twilio.json >&2
        fail "Twilio API returned HTTP $status"
    fi
    ok "Twilio VoiceUrl → ${BOLD}${WEBHOOK_URL}${NC}"
}

wait_for_health() {
    note "Waiting for backend health..."
    for i in $(seq 1 30); do
        if curl -fsS --max-time 3 "http://127.0.0.1:${BACKEND_PORT}/api/health" >/dev/null 2>&1; then
            ok "Backend healthy"
            return
        fi
        sleep 3
    done
    warn "Backend not healthy after 90s — check: talkbox logs"
}

summary_box() {
    # NB: docker-compose binds 127.0.0.1 only — the kiosk is reachable on this
    # machine, not on the LAN, unless compose is edited.
    local enabled; enabled=$(curl -s --max-time 3 "http://127.0.0.1:${BACKEND_PORT}/api/kiosk/config" 2>/dev/null \
        | python3 -c "import sys,json; print('yes' if json.load(sys.stdin).get('calling_enabled') else 'NO')" 2>/dev/null || echo "?")
    echo ""
    echo -e "${GREEN}${BOLD}  ╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}${BOLD}  ║  Talk Box is live                                         ║${NC}"
    echo -e "${GREEN}${BOLD}  ╠═══════════════════════════════════════════════════════════╣${NC}"
    printf "  ${GREEN}║${NC}  Kiosk     ${BOLD}%-46s${NC} ${GREEN}║${NC}\n" "http://localhost:${FRONTEND_PORT}/kiosk"
    printf "  ${GREEN}║${NC}  Demo      %-46s ${GREEN}║${NC}\n" "http://localhost:${FRONTEND_PORT}/demo"
    printf "  ${GREEN}║${NC}  Public    %-46s ${GREEN}║${NC}\n" "${PUBLIC_BASE_URL}"
    printf "  ${GREEN}║${NC}  Webhook   %-46s ${GREEN}║${NC}\n" "${WEBHOOK_URL}"
    printf "  ${GREEN}║${NC}  Calling   %-46s ${GREEN}║${NC}\n" "enabled: ${enabled}"
    echo -e "${GREEN}${BOLD}  ╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# ── Commands ──────────────────────────────────────────────────────────────────
cmd_update() {
    STEP_TOTAL=4
    banner
    cd "$REPO_DIR"
    require_env

    step "Pulling latest from git"
    if ! git diff --quiet || ! git diff --cached --quiet; then
        warn "Working tree has local changes — pulling anyway (ff-only)."
    fi
    local before after
    before=$(git rev-parse --short HEAD)
    git pull --ff-only 2>&1 | sed 's/^/  /'
    after=$(git rev-parse --short HEAD)
    if [ "$before" = "$after" ]; then
        ok "Already up to date ($after)"
    else
        ok "Updated $before → $after"
        git log --oneline "$before..$after" | head -5 | sed 's/^/    /'
    fi

    step "Publishing webhook to Twilio"
    publish_to_twilio

    step "Rebuilding and relaunching containers"
    docker compose up -d --build 2>&1 | grep -E 'Built|Started|Healthy|Error' | sed 's/^ */  /' || true
    ok "Stack relaunched"

    step "Health check"
    wait_for_health

    # Reload Chromium so it picks up the new JS bundle (browser caches the old
    # one and never fetches the new index.html unless explicitly refreshed).
    if pgrep -x chromium-browser >/dev/null 2>&1 || pgrep -x chromium >/dev/null 2>&1; then
        note "Reloading Chromium kiosk browser..."
        DISPLAY=:0 xdotool key ctrl+F5 2>/dev/null \
            || DISPLAY=:0 xdotool key F5 2>/dev/null \
            || true
        ok "Browser refresh sent"
    fi

    summary_box
}

cmd_twilio_sync() {
    STEP_TOTAL=2
    cd "$REPO_DIR"
    require_env

    step "Publishing webhook to Twilio"
    publish_to_twilio

    step "Syncing backend"
    # Compare against the *container's* env — that's what signature validation
    # actually uses. (.env alone can be right while the container is stale.)
    local container_url
    container_url="$(docker exec talkbox-backend printenv TWILIO_PUBLIC_URL 2>/dev/null || true)"
    container_url="$(normalize_public_base_url "$container_url")"
    if [ "$container_url" = "$PUBLIC_BASE_URL" ]; then
        ok "Backend already has $PUBLIC_BASE_URL — no restart needed"
    else
        note "Backend env stale ('$container_url') — recreating (restart won't reload .env)..."
        docker compose up -d --force-recreate talkbox-backend >/dev/null 2>&1
        wait_for_health
    fi
    summary_box
}

twilio_voice_url() {
    curl -s --max-time 10 -u "${TWILIO_ACCOUNT_SID}:${TWILIO_AUTH_TOKEN}" \
        "https://api.twilio.com/2010-04-01/Accounts/${TWILIO_ACCOUNT_SID}/Applications/${TWIML_APP_SID}.json" 2>/dev/null \
        | python3 -c "import sys,json; print(json.load(sys.stdin).get('voice_url',''))" 2>/dev/null || true
}

cmd_watchdog() {
    # Periodic self-heal: verify .env ↔ backend container ↔ Twilio are in sync.
    cd "$REPO_DIR"
    require_env

    local env_url container_url voice_url drift=""
    env_url="$(normalize_public_base_url "$(env_val TWILIO_PUBLIC_URL)")"
    container_url="$(docker exec talkbox-backend printenv TWILIO_PUBLIC_URL 2>/dev/null || true)"
    container_url="$(normalize_public_base_url "$container_url")"

    if [ "$env_url" != "$PUBLIC_BASE_URL" ]; then
        drift=".env has '$env_url'"
    elif [ "$container_url" != "$PUBLIC_BASE_URL" ]; then
        drift="backend container has '$container_url'"
    else
        voice_url="$(twilio_voice_url)"
        # Empty = Twilio API unreachable (offline?) — don't thrash, check next run.
        if [ -n "$voice_url" ] && [ "$voice_url" != "${WEBHOOK_URL}" ]; then
            drift="Twilio VoiceUrl is '$voice_url'"
        fi
    fi

    if [ -z "$drift" ]; then
        ok "watchdog: in sync (${WEBHOOK_URL})"
        return 0
    fi

    warn "watchdog: $drift — repairing..."
    cmd_twilio_sync
}

cmd_status() {
    cd "$REPO_DIR"
    banner
    echo -e "${BOLD}Containers${NC}"
    docker ps --filter "name=talkbox-" --format "  {{.Names}}\t{{.Status}}" || true
    echo ""
    echo -e "${BOLD}Health${NC}"
    if curl -fsS --max-time 3 "http://127.0.0.1:${BACKEND_PORT}/api/health" >/dev/null 2>&1; then
        ok "backend /api/health"
    else
        warn "backend unreachable on :${BACKEND_PORT}"
    fi
    echo ""
    echo -e "${BOLD}Public URL + Twilio${NC}"
    if [ -f "$ENV_FILE" ]; then
        require_env
        local voice_url
        voice_url=$(curl -s -u "${TWILIO_ACCOUNT_SID}:${TWILIO_AUTH_TOKEN}" \
            "https://api.twilio.com/2010-04-01/Accounts/${TWILIO_ACCOUNT_SID}/Applications/${TWIML_APP_SID}.json" 2>/dev/null \
            | python3 -c "import sys,json; print(json.load(sys.stdin).get('voice_url',''))" 2>/dev/null || true)
        ok "TWILIO_PUBLIC_URL (base): $PUBLIC_BASE_URL"
        note "Expected Twilio VoiceUrl: $WEBHOOK_URL"
        if [ -n "$voice_url" ]; then
            if [ "$voice_url" = "$WEBHOOK_URL" ]; then
                ok "Twilio VoiceUrl matches expected webhook: $voice_url"
            else
                warn "Twilio VoiceUrl: ${voice_url:-"(unset)"}"
                warn "→ out of sync — run: talkbox twilio-sync"
            fi
        fi
        note "TWILIO_PUBLIC_URL in .env: $(env_val TWILIO_PUBLIC_URL)"
    fi
    echo ""
}

cmd_restart() {
    cd "$REPO_DIR"
    echo -e "${BOLD}Restarting stack...${NC}"
    docker compose restart
    wait_for_health
    require_env
    summary_box
}

cmd_logs() {
    cd "$REPO_DIR"
    docker logs -f --tail 100 "${1:-talkbox-backend}"
}

kiosk_launch_cmd() {
    # The exact command the desktop session uses to start the kiosk browser.
    # Prefer the autostart entry so we stay in sync with how the Pi boots it;
    # fall back to a sane default targeting the frontend port.
    local desktop="$HOME/.config/autostart/kiosk.desktop"
    if [ -f "$desktop" ]; then
        local exec_line
        exec_line=$(grep -E '^Exec=' "$desktop" | head -1 | cut -d= -f2-)
        if [ -n "$exec_line" ]; then
            printf '%s' "$exec_line"
            return
        fi
    fi
    printf '%s' "chromium --kiosk --noerrdialogs --disable-infobars --no-first-run http://localhost:${FRONTEND_PORT}/kiosk"
}

cmd_refresh() {
    # Reload the on-screen kiosk browser without rebooting. Vite assets are
    # content-hashed, so a plain reload picks up the latest build.
    local disp="${DISPLAY:-:0}"
    local xauth="${XAUTHORITY:-$HOME/.Xauthority}"

    # Preferred: soft in-place reload via xdotool (no flicker), if available.
    if command -v xdotool >/dev/null 2>&1; then
        local wid
        wid=$(DISPLAY="$disp" XAUTHORITY="$xauth" xdotool search --class chromium 2>/dev/null | head -1)
        if [ -n "$wid" ]; then
            DISPLAY="$disp" XAUTHORITY="$xauth" xdotool key --window "$wid" ctrl+shift+r
            ok "Sent hard-reload (Ctrl+Shift+R) to kiosk browser"
            return
        fi
    fi

    # Fallback: kill Chromium and relaunch it ourselves. Nothing else respawns
    # it — the desktop autostart entry only fires once at session start.
    note "xdotool not available — restarting Chromium..."
    pkill -f "chromium" 2>/dev/null || true
    sleep 2

    local cmd; cmd="$(kiosk_launch_cmd)"
    DISPLAY="$disp" XAUTHORITY="$xauth" setsid bash -c "$cmd" >/tmp/talkbox-kiosk.log 2>&1 &
    disown

    for i in 1 2 3 4 5 6; do
        sleep 2
        if pgrep -f "chromium .*--kiosk" >/dev/null 2>&1; then
            ok "Kiosk browser relaunched on $disp"
            note "Tip: 'sudo apt install xdotool' enables instant flicker-free reloads"
            return
        fi
    done
    warn "Chromium did not come back — check /tmp/talkbox-kiosk.log"
}

cmd_install() {
    mkdir -p "$HOME/.local/bin"
    ln -sf "$SCRIPT_PATH" "$HOME/.local/bin/talkbox"
    ok "Symlinked: ~/.local/bin/talkbox → $SCRIPT_PATH"
    case ":$PATH:" in
        *":$HOME/.local/bin:"*) ok "~/.local/bin already on PATH" ;;
        *)
            if ! grep -q '\.local/bin' "$HOME/.bashrc" 2>/dev/null; then
                printf '\n# talkbox CLI\nexport PATH="$HOME/.local/bin:$PATH"\n' >> "$HOME/.bashrc"
                ok "Added ~/.local/bin to PATH in ~/.bashrc"
            fi
            warn "Open a new shell (or: source ~/.bashrc) then run: talkbox update"
            ;;
    esac
}

usage() {
    banner
    echo -e "  ${BOLD}talkbox update${NC}       git pull → rebuild → relaunch → Twilio → health"
    echo -e "  ${BOLD}talkbox twilio-sync${NC}  publish webhook to Twilio and sync backend"
    echo -e "  ${BOLD}talkbox status${NC}       containers, health, public URL, Twilio sync"
    echo -e "  ${BOLD}talkbox watchdog${NC}     check .env/backend/Twilio sync, repair if drifted"
    echo -e "  ${BOLD}talkbox restart${NC}   restart containers (no rebuild)"
    echo -e "  ${BOLD}talkbox refresh${NC}   reload the on-screen kiosk browser (no reboot)"
    echo -e "  ${BOLD}talkbox logs${NC}      tail backend logs  (talkbox logs talkbox-frontend)"
    echo -e "  ${BOLD}talkbox install${NC}   put 'talkbox' on your PATH"
    echo ""
}

case "${1:-}" in
    update)  cmd_update ;;
    twilio-sync) shift; cmd_twilio_sync "$@" ;;
    status)  cmd_status ;;
    watchdog) cmd_watchdog ;;
    restart) cmd_restart ;;
    refresh) cmd_refresh ;;
    logs)    shift || true; cmd_logs "$@" ;;
    install) cmd_install ;;
    *)       usage ;;
esac
