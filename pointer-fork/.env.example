# ───── Postgres (pgvector) ─────
POSTGRES_DB=pointer
POSTGRES_USER=pointer
POSTGRES_PASSWORD=change-me

# ───── LLM provider ─────
# openai | bedrock
LLM_PROVIDER=openai
MODEL=gpt-4o-mini
MODEL_TEMPERATURE=0.0

# OpenAI — required when LLM_PROVIDER=openai or EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=

# Embeddings backend: openai | bedrock
# Changing providers invalidates the pgvector dimensions — rotate COLLECTION_NAME
# when switching, or drop the existing langchain_pg_* tables.
EMBEDDINGS_PROVIDER=openai
# openai default: text-embedding-3-small (1536 dim)
# bedrock options: amazon.titan-embed-text-v2:0 (1024), cohere.embed-english-v3 (1024)
EMBEDDINGS_MODEL=text-embedding-3-small
COLLECTION_NAME=query_categories

# AWS Bedrock — required when LLM_PROVIDER=bedrock or EMBEDDINGS_PROVIDER=bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ───── Database ─────
DB_URI=postgresql+psycopg://pointer:change-me@pointer-postgres:5432/pointer
DB_NAME=sacramento
DB_TABLE_NAME=sacramento

# ───── Observability ─────
LOG_FILE=app.log
LOG_LEVEL=info

# ───── HTTP / CORS ─────
CORS_ORIGINS=*

# ───── Auth (fastapi-users, cookie JWT) ─────
# Rotate before first real deploy; generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
# Set to 1 behind HTTPS, 0 for plain-HTTP local dev
COOKIE_SECURE=1
# URL shown in future verify/reset emails
FRONTEND_URL=http://localhost:8084

# Admin user bootstrap (seeded on first boot, idempotent)
# Must be a real-looking email: pydantic EmailStr rejects .local/.test/.invalid TLDs
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin
ADMIN_COMPANY=

# ───── Twilio (SMS webhook + outbound kiosk calls — optional) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Enable real outbound calls from the kiosk Dial tab (numbers must be in the
# agencies DB allowlist, or match KIOSK_TEST_CALL_NUMBER).
KIOSK_CALLING_ENABLED=false
# Comma-separated list of E.164 numbers allowed outside the DB allowlist.
# On Twilio trial accounts, only verified numbers can be called.
KIOSK_TEST_CALL_NUMBERS=

# ───── Kiosk (keypad-first 6-inch UX) ─────
# When true, /api/kiosk/query returns curated sample resources instead of
# calling OpenAI + pgvector. Lets the kiosk demo run with no API key / seeded DB.
KIOSK_MOCK_QUERY=false
# Seconds of inactivity before the kiosk auto-resets to the idle menu.
KIOSK_IDLE_RESET_SECONDS=60

# ───── Frontend (build-time) ─────
VITE_API_URL=
VITE_APP_NAME=Pointer AI

# ───── Docker image tags (overridden by CI) ─────
IMAGE_BACKEND=ghcr.io/la-plas-growth/pointer-backend:latest
IMAGE_FRONTEND=ghcr.io/la-plas-growth/pointer-frontend:latest
